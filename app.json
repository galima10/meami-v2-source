{
  "expo": {
    "name": "Meami",
    "slug": "meamiv2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/precharged/logos/icon.png",
    "scheme": "meami",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.meami.app",
      "versionCode": 1,
      "icon": "./assets/images/precharged/logos/adaptive_icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/precharged/logos/adaptive_icon.png",
        "backgroundColor": "#491B1E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/precharged/logos/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E09873"
        }
      ],
      "expo-asset",
      "expo-sqlite"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/04918abf-e8aa-4a94-a689-1de474bddc6e"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "expoRouterAppRoot": "./app"
      },
      "eas": {
        "projectId": "04918abf-e8aa-4a94-a689-1de474bddc6e"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
