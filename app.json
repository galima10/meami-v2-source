{
  "expo": {
    "name": "Meami",
    "slug": "meamiv2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/precharged/logos/icon.png",
    "scheme": "meami",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.meami.app",
      "versionCode": 1,
      "icon": "./assets/images/precharged/logos/adaptive_icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/precharged/logos/adaptive_icon.png",
        "backgroundColor": "#491B1E"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/precharged/logos/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E09873"
        }
      ],
      "expo-asset",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": true,
          "android": {
            "enableFTS": false,
            "useSQLCipher": false
          },
          "ios": {
            "customBuildFlags": [
              "-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
            ]
          }
        }
      ],
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "SN",
                "fontDefinitions": [
                  { "path": "./assets/fonts/SN_Regular.ttf", "weight": 400 },
                  { "path": "./assets/fonts/SN_Medium.ttf", "weight": 500 },
                  { "path": "./assets/fonts/SN_SemiBold.ttf", "weight": 600 },
                  { "path": "./assets/fonts/SN_Bold.ttf", "weight": 700 }
                ]
              }
            ]
          }
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/04918abf-e8aa-4a94-a689-1de474bddc6e"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "expoRouterAppRoot": "./app"
      },
      "eas": {
        "projectId": "04918abf-e8aa-4a94-a689-1de474bddc6e"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
